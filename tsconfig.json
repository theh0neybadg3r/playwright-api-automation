{
  "compilerOptions": {
    "esModuleInterop": true,
    "noImplicitAny": true,
    "noImplicitThis": true,
    "alwaysStrict": true,
    "strictNullChecks": false,
    "paths": {
      "@const/*": ["./helpers/const/*"],
      "@fixtures/*": ["./fixtures/*"],
      "@models/*": ["./helpers/models/*"],
      "@pages/*": ["./pages/*"],
      "@utils/*": ["./helpers/utils/*"]
    }
  }
}
